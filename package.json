{
  "name": "silk-beauty-salon",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "set NODE_OPTIONS=--max-old-space-size=4096 && next dev -p 3000 --turbopack --hostname 0.0.0.0",
    "dev:alt": "next dev -p 3001",
    "build": "BUILD_TIMESTAMP=$(date -u +%Y-%m-%dT%H:%M:%SZ) next build && node -e \"const fs=require('fs');const p=require('path');['static','../public'].forEach((s,i)=>{const d=i?'standalone/public':'standalone/.next/static';try{fs.cpSync(s,d,{recursive:true})}catch(e){}})\"",
    "start": "NODE_ENV=production bun .next/standalone/server.js 2>&1 | tee server.log",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:a11y": "playwright test e2e/accessibility.spec.ts",
    "validate:i18n": "tsx scripts/validate-translations.ts",
    "security:audit": "tsx scripts/security-audit.ts",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:migrate:sqlite-to-postgres": "tsx scripts/migrate-to-postgres.ts",
    "db:backup": "tsx scripts/db-backup.ts full",
    "db:backup:list": "tsx scripts/db-backup.ts list",
    "db:backup:verify": "tsx scripts/backup-verify.ts",
    "db:restore": "tsx scripts/db-restore.ts restore",
    "db:docker:up": "docker-compose up -d postgres pgbouncer",
    "db:docker:down": "docker-compose down",
    "db:docker:logs": "docker-compose logs -f postgres",
    "db:health": "curl -s http://localhost:3000/api/health/db | head -c 500",
    "test:lighthouse": "lhci autorun",
    "analyze": "BUNDLE_ANALYZE=true npm run build"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-accordion": "^1.2.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.5",
    "@radix-ui/react-toast": "^1.2.14",
    "@react-email/components": "^1.0.12",
    "@react-email/render": "^2.0.7",
    "@sentry/nextjs": "^10.51.0",
    "@tanstack/react-query": "^5.100.6",
    "@tanstack/react-query-devtools": "^5.100.6",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "axe-core": "^4.11.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "framer-motion": "^12.38.0",
    "isomorphic-dompurify": "^3.10.0",
    "lucide-react": "^0.525.0",
    "next": "^16.2.4",
    "next-intl": "^4.9.1",
    "react": "^19.0.0",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.74.0",
    "resend": "^6.1.3",
    "sharp": "^0.34.3",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.0.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.3",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.5",
    "axe-playwright": "^2.2.2",
    "bun-types": "^1.3.4",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "^16.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "next-swagger-doc": "^0.4.1",
    "pa11y": "^9.1.1",
    "playwright": "^1.59.1",
    "prisma": "^5.22.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "swagger-ui-react": "^5.32.5",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.3.5",
    "typescript": "^5",
    "vitest": "^4.1.5"
  },
  "prisma": {
    "seed": "npx ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "tsc --noEmit --skipLibCheck"
    ]
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
