    {
      "name": "Treatments",
      "item": [
        {
          "name": "List Treatments",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/treatments?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "treatments"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            }
          },
          "response": []
        }
      ]
    }
