          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"consent\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/newsletter/subscribe",
