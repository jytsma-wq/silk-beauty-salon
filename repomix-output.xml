}

/* Hairline separator */
.hairline {
  width: 100%;
  height: 1px;
  background: #e8e4df;
}

/* French link style — underline grows from left */
.link-french {
  position: relative;
  color: #1c1c1c;
  text-decoration: none;
  font-size: 0.75rem;
  letter-spacing: 0.12em;
