}

.editorial-list-title {
  font-family: var(--font-serif), Georgia, serif;
  font-size: 1.25rem;
  font-weight: 400;
  color: #1c1c1c;
  margin-bottom: 0.25rem;
  letter-spacing: -0.01em;
}

.editorial-list-desc {
  font-family: var(--font-sans), Inter, sans-serif;
  font-size: 0.875rem;
