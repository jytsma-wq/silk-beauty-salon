}

.editorial-list-item:hover::before {
  transform: scaleY(1);
}

.editorial-list-item:hover .editorial-list-title {
  color: #b5453a;
}

/* Brand Manifesto Section */
.manifesto-section {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  padding: 140px 4vw;
}

.manifesto-text-large {
  font-family: var(--font-serif), Georgia, serif;
  font-size: clamp(2rem, 8vw, 5rem);
  font-weight: 400;
  line-height: 1.1;
  letter-spacing: -0.03em;
  color: #1c1c1c;
  text-align: center;
  max-width: 12ch;
}

/* Statistics as Art */
.stats-art {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 0;
  background: #f7f4f0;
  padding: 100px 4vw;
}

.stat-item {
  text-align: center;
  padding: 0 3vw;
  position: relative;
}

.stat-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1px;
  height: 60%;
  background: #d0ccc7;
}

.stat-number {
  font-family: var(--font-serif), Georgia, serif;
  font-size: clamp(2.5rem, 6vw, 4.5rem);
  font-weight: 400;
  letter-spacing: -0.04em;
  color: #1c1c1c;
  line-height: 1;
}

.stat-desc {
  font-family: var(--font-sans), Inter, sans-serif;
  font-size: 0.625rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #9a9a9a;
  margin-top: 0.75rem;
}

/* Asymmetric Image/Text Split */
.asymmetric-split {
  display: grid;
  min-height: 600px;
}

.asymmetric-split-left {
  grid-template-columns: 55% 45%;
}

.asymmetric-split-right {
  grid-template-columns: 40% 60%;
}

@media (max-width: 768px) {
  .asymmetric-split,
  .asymmetric-split-left,
  .asymmetric-split-right {
    grid-template-columns: 1fr;
  }
}

/* Borderless, shadowless cards */
.card-luxury {
  background: #ffffff;
  padding: 2rem;
  transition: background-color 0.3s ease;
}

.card-luxury:hover {
  background: #fafafa;
}

/* Remove all borders and shadows from UI elements */
.no-border {
  border: none !important;
}

.no-shadow {
  box-shadow: none !important;
}

/* ============================================
   PROMPT 8: Additional Animation Keyframes
   & French Luxury Utilities
   ============================================ */

/* 1. KEN BURNS EFFECT */
@keyframes kenBurns {
  0% { transform: scale(1); }
  100% { transform: scale(1.05); }
}

.ken-burns {
  animation: kenBurns 12s ease-out forwards;
}

/* 2. REVEAL FROM LEFT */
@keyframes revealLeft {
  from { clip-path: inset(0 100% 0 0); }
  to { clip-path: inset(0 0 0 0); }
}

.reveal-left {
  animation: revealLeft 1.2s ease-out forwards;
}

/* 3. REVEAL FROM RIGHT */
@keyframes revealRight {
  from { clip-path: inset(0 0 0 100%); }
  to { clip-path: inset(0 0 0 0); }
}

.reveal-right {
  animation: revealRight 1.2s ease-out forwards;
}

/* 4. FADE IN UP SLOW (for hero text) */
@keyframes fadeInUpSlow {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}

.fade-in-up-slow {
  animation: fadeInUpSlow 0.8s ease-out forwards;
}

/* 5. PULSE SUBTLE (for scroll indicator) */
@keyframes pulseSubtle {
  0%, 100% { opacity: 0.3; }
  50% { opacity: 0.8; }
}

.pulse-subtle {
  animation: pulseSubtle 2s ease-in-out infinite;
}

/* 6. SMOOTH SCROLL PROGRESS BAR */
.scroll-progress {
  transition: width 0.1s linear;
}

/* 7. HERO VIDEO WRAPPER */
.hero-video-wrapper {
  position: absolute;
  inset: 0;
  overflow: hidden;
}

.hero-video-wrapper video {
  position: absolute;
  top: 50%;
  left: 50%;
  min-width: 100%;
  min-height: 100%;
  transform: translate(-50%, -50%);
  object-fit: cover;
  will-change: transform;
}

/* 8. TRANSPARENT HEADER UTILITY */
.header-transparent {
  background: transparent;
  color: white;
  border: none;
  box-shadow: none;
}

.header-transparent a,
.header-transparent button,
.header-transparent span {
  color: white;
}

/* 9. FROSTED GLASS UTILITY */
.frosted-glass {
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
}

/* 10. MAGAZINE SECTION DIVIDER */
.magazine-divider {
  width: 100%;
  height: 1px;
  background: linear-gradient(to right, transparent, #d0ccc7 20%, #d0ccc7 80%, transparent);
  margin: 0 auto;
  max-width: 200px;
}

/* 11. PRESS BAR MARQUEE ANIMATION */
@keyframes marquee {
  0% {
    transform: translateX(0%);
  }
  100% {
    transform: translateX(-33.333%);
  }
}

.animate-marquee {
  animation: marquee 20s linear infinite;
  will-change: transform;
}
