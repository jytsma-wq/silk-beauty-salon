<file path="prisma/schema.prisma">
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// PostgreSQL Enums for status fields

enum ContactStatus {
  NEW
  IN_PROGRESS
  COMPLETED
  ARCHIVED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum SubscriberStatus {
  ACTIVE
  UNSUBSCRIBED
  BOUNCED
}

model ContactSubmission {
  id        String         @id @default(uuid()) @db.Uuid
  name      String
  email     String
  phone     String?
  message   String
  locale    String         @default("en")
  createdAt DateTime       @default(now())
  status    ContactStatus  @default(NEW)

  @@index([status, createdAt])
  @@index([email])
}

model BookingRequest {
  id            String        @id @default(uuid()) @db.Uuid
  name          String
  email         String
  phone         String
  service       String
  preferredDate DateTime?
  preferredTime String?
  message       String?
  locale        String        @default("en")
  createdAt     DateTime      @default(now())
  status        BookingStatus @default(PENDING)

  @@index([status, createdAt])
  @@index([email])
  @@index([preferredDate])
}

model NewsletterSubscriber {
  id        String           @id @default(uuid()) @db.Uuid
  email     String           @unique
  locale    String           @default("en")
  createdAt DateTime         @default(now())
  status    SubscriberStatus @default(ACTIVE)

  @@index([status, createdAt])
}

model BlogPost {
  id         String   @id @default(uuid()) @db.Uuid
  title      String
  slug       String
  excerpt    String   @default("")
  content    String   @default("")
  image      String   @default("")
  category   String   @default("")
  author     String   @default("")
  readTime   String   @default("5 min")
  locale     String   @default("en")
  published  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([slug, locale])
  @@index([published, createdAt])
  @@index([category, locale])
}

// Treatment Category - base data (images, slugs are non-translatable)
model TreatmentCategory {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  image       String
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  translations TreatmentCategoryTranslation[]
  treatments   Treatment[]

  @@index([slug])
  @@index([active, sortOrder])
}

// Treatment Category Translations (i18n content)
model TreatmentCategoryTranslation {
  id          String            @id @default(uuid()) @db.Uuid
  categoryId  String            @db.Uuid
  locale      String            // en, ka, ru, ar, he, tr
  name        String
  description String

  // Relations
  category    TreatmentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@index([locale])
}

// Individual Treatment - base data
model Treatment {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique
  image       String
  price       String?  // e.g., "From ₾200"
  duration    String?  // e.g., "15-30 minutes"
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  categoryId  String   @db.Uuid
  category    TreatmentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  translations TreatmentTranslation[]
  benefits     TreatmentBenefit[]
  faqs         TreatmentFAQ[]

  @@index([slug])
  @@index([categoryId])
  @@index([active, sortOrder])
}

// Treatment Translations (i18n content)
model TreatmentTranslation {
  id              String    @id @default(uuid()) @db.Uuid
  treatmentId     String    @db.Uuid
  locale          String    // en, ka, ru, ar, he, tr
  name            String
  description     String
  shortDescription String
  howItWorks      String?
  aftercare       String?

  // Relations
  treatment       Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@unique([treatmentId, locale])
  @@index([locale])
}

// Treatment Benefits (translatable array items)
model TreatmentBenefit {
  id          String    @id @default(uuid()) @db.Uuid
  treatmentId String    @db.Uuid
  locale      String
  text        String
  sortOrder   Int       @default(0)

  // Relations
  treatment   Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@index([treatmentId, locale])
  @@index([sortOrder])
}

// Treatment FAQs (translatable Q&A)
model TreatmentFAQ {
  id          String    @id @default(uuid()) @db.Uuid
  treatmentId String    @db.Uuid
  locale      String
  question    String
  answer      String
  sortOrder   Int       @default(0)

  // Relations
  treatment   Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@index([treatmentId, locale])
  @@index([sortOrder])
}

// Booking model for calendar-based appointment system
model Booking {
  id          String        @id @default(uuid()) @db.Uuid
  name        String
  email       String
  phone       String?
  service     String
  date        DateTime
  timeSlot    String        // e.g. "09:00 - 10:00"
  message     String?
  status      BookingStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([date, status])
  @@index([status, createdAt])
  @@index([email])
}
</file>

