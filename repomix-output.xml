}

/* ─────────────────────────────────────────────────────────────
   FRENCH MAGAZINE DESIGN SYSTEM
   ───────────────────────────────────────────────────────────── */

/* 2. Remove all card borders and shadows (borderless French style) */
.editorial-card {
  border: none;               /* was: 1px solid #e0e0e0 */
  background: transparent;    /* was: #ffffff */
