// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  locale    String   @default("en")
  createdAt DateTime @default(now())
  status    String   @default("new")
}

model BookingRequest {
  id            String   @id @default(cuid())
  name          String
  email         String
  phone         String
  service       String
  preferredDate String?
  preferredTime String?
  message       String?
  locale        String   @default("en")
  createdAt     DateTime @default(now())
  status        String   @default("pending")

  @@index([status, createdAt])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  locale    String   @default("en")
  createdAt DateTime @default(now())
  active    Boolean  @default(true)
}

model BlogPost {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  excerpt     String
  content     String
  image       String
  category    String
  author      String   @default("Silk Beauty Team")
  readTime    String   @default("5 min read")
  locale      String   @default("en")
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([locale, published])
}

// Treatment Category - base data (images, slugs are non-translatable)
model TreatmentCategory {
  id          String   @id @default(cuid())
  slug        String   @unique
  image       String
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  translations TreatmentCategoryTranslation[]
  treatments   Treatment[]

  @@index([slug])
  @@index([active, sortOrder])
}

// Treatment Category Translations (i18n content)
model TreatmentCategoryTranslation {
  id          String   @id @default(cuid())
  categoryId  String
  locale      String   // en, ka, ru, ar, he, tr
  name        String
  description String

  // Relations
  category    TreatmentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@index([locale])
}

// Individual Treatment - base data
model Treatment {
  id          String   @id @default(cuid())
  slug        String   @unique
  image       String
  price       String?  // e.g., "From ₾200"
  duration    String?  // e.g., "15-30 minutes"
  sortOrder   Int      @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  categoryId  String
  category    TreatmentCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  translations TreatmentTranslation[]
  benefits     TreatmentBenefit[]
  faqs         TreatmentFAQ[]

  @@index([slug])
  @@index([categoryId])
  @@index([active, sortOrder])
}

// Treatment Translations (i18n content)
model TreatmentTranslation {
  id              String   @id @default(cuid())
  treatmentId     String
  locale          String   // en, ka, ru, ar, he, tr
  name            String
  description     String
  shortDescription String
  howItWorks      String?
  aftercare       String?

  // Relations
  treatment       Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@unique([treatmentId, locale])
  @@index([locale])
}

// Treatment Benefits (translatable array items)
model TreatmentBenefit {
  id          String   @id @default(cuid())
  treatmentId String
  locale      String
  text        String
  sortOrder   Int      @default(0)

  // Relations
  treatment   Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@index([treatmentId, locale])
  @@index([sortOrder])
}

// Treatment FAQs (translatable Q&A)
model TreatmentFAQ {
  id          String   @id @default(cuid())
  treatmentId String
  locale      String
  question    String
  answer      String
  sortOrder   Int      @default(0)

  // Relations
  treatment   Treatment @relation(fields: [treatmentId], references: [id], onDelete: Cascade)

  @@index([treatmentId, locale])
  @@index([sortOrder])
}

// Booking model for calendar-based appointment system
model Booking {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  service     String
  date        String   // ISO date string YYYY-MM-DD
  timeSlot    String   // e.g. "09:00 - 10:00"
  message     String?
  status      String   @default("pending") // pending, confirmed, cancelled
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date, status])
  @@index([status, createdAt])
}